{
  "name": "halide-demo",
  "version": "0.0.0",
  "private": true,
  "description": "A declarative BFF runtime with auth, proxy, CSP, rate limiting, and OpenAPI support",
  "license": "MIT",
  "author": "kevinchatham",
  "workspaces": [
    "projects/*"
  ],
  "scripts": {
    "halide:link": "npm link halide",
    "halide:unlink": "npm unlink halide",
    "kill": "fuser -k -n tcp 3000 && fuser -k -n tcp 3553",
    "lint:fix": "biome check --config-path biome.json  --write . && prettier --write . --config .prettierrc --ignore-path .prettierignore",
    "lint:watch": "nodemon --exec 'npm run lint:fix' --watch '**/*.ts' --watch '**/*.json' --ext '.ts,.json'",
    "lint": "biome check --config-path biome.json .",
    "skills:link": "rm -rf .kilo/skills/halide && ln -s ../../.agents/skills/halide .kilo/skills/halide",
    "skills:update": "halide init --skills-only",
    "prestart": "cd projects/shared && npm run build",
    "start": "npx concurrently --names \"shared,backend,angular\" --prefix-colors \"cyan,yellow,magenta\" \"npm run serve --prefix projects/shared\" \"npm run serve --prefix projects/backend\" \"npm run serve:angular --prefix projects/angular\""
  },
  "dependencies": {
    "halide": "^0.0.9",
    "jose": "^6.2.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/node": "^24.0.0",
    "jsdom": "^28.0.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
